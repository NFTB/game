{
  "players": {
    "min": 2,
    "max": 4,
    "initial_gold": 10000000
  },
  "rounds": {
    "count": 5,
    "time_limit_seconds": 30,
    "entry_fee_timing": "round_start"
  },
  "warehouse": {
    "lot_type": "warehouse",
    "winner_gets_all": true,
    "theoretical_grid": {
      "rows": 200,
      "cols": 10
    },
    "requires_full_fill": false,
    "layout_rules": {
      "vertical_no_gaps": true,
      "allow_top_overhang": true,
      "no_stack_on_overhang": true,
      "column_height_order": "non_strict_descending_left_to_right"
    }
  },
  "bidding": {
    "mode": "blind",
    "min_bid": 1,
    "max_bid": "current_gold",
    "allow_no_bid": true,
    "winner": "highest_bid",
    "charge_bid_on_win": true,
    "early_win_thresholds": [2.0, 1.6, 1.3, 1.1, 0],
    "reveal_on_early_win": "all_bids",
    "reveal_without_early_win": "bid_rankings"
  },
  "tiebreaker": {
    "type": "rebid",
    "participants": "highest_tied_players",
    "mode": "blind",
    "max_rounds": 10,
    "must_exceed_previous": true,
    "unresolved_result": "void_warehouse"
  },
  "clues": {
    "types": ["轮廓", "稀有度", "类型"],
    "public_source": "map",
    "item_source_visibility": "owner_only",
    "empty_estimate": 0,
    "estimate_basis": "minimum_true_value_from_known_clues"
  },
  "items": {
    "loadout_limit": 5,
    "use_limit_per_round": 1,
    "configured_before_match": true,
    "consume_inventory_on_use": true,
    "default_visibility": "owner_only"
  },
  "collectibles": {
    "tiers": ["N", "R", "SR", "SSR"],
    "types": ["瓷器", "书画", "玉器", "青铜器", "杂项"],
    "sell_value": "true_value"
  },
  "roles": {
    "enabled": false,
    "reserved": true
  },
  "npc": {
    "enabled_for_local_demo": true,
    "valuation_model": "clue_accuracy_based",
    "risk_profiles": ["conservative", "balanced", "aggressive"]
  }
}
